# ---------------------------------------------------------------------
# Variables d'environnement — app-notification
# ---------------------------------------------------------------------
# Copie ce fichier en .env.local puis remplis les valeurs ci-dessous.
# En production, mets ces mêmes variables dans Vercel → Settings →
# Environment Variables.
# ---------------------------------------------------------------------

# ====== OBLIGATOIRE — Supabase ====================================
# Récupère ces 3 valeurs dans Supabase → Project Settings → API Keys.
# Utiliser l'onglet « Legacy anon, service_role API keys ».
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...your-service-role-secret-key

# ====== OBLIGATOIRE pour le cron des planifications ===============
# Génère avec: openssl rand -hex 32
# (En prod, ajoute la même valeur dans Vercel pour que Vercel Cron
# puisse appeler /api/cron/run-schedules avec ce header.)
CRON_SECRET=replace-with-a-long-random-string

# ====== EMAIL (provider d'envoi) ==================================
# Provider: 'mock' (dev, n'envoie rien) ou 'resend' (vrais envois)
EMAIL_PROVIDER=mock
EMAIL_FROM=noreply@example.com
RESEND_API_KEY=

# Test du retry — probabilité d'échec simulée du mock (0.0 — 1.0)
EMAIL_MOCK_FAIL_RATE=0

# ====== SMS (optionnel) ===========================================
# Provider: 'mock' ou 'twilio'
SMS_PROVIDER=mock
SMS_FROM=+15555555555
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SMS_MOCK_FAIL_RATE=0

# ====== MONITORING (optionnel) ====================================
# Si défini, toutes les erreurs sont POSTées à cette URL.
# Compatible avec webhook Discord, Slack, Axiom, Logsnag, Sentry HTTP...
# Format payload: { ts, app, message, stack?, digest?, url?, userId? }
ERROR_WEBHOOK_URL=

# ====== WHATSAPP (futur) ==========================================
# WHATSAPP_PROVIDER=mock
